{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "EncryptionKey": "CHANGEME-GENERATE-A-32-BYTE-BASE64-KEY-HERE",
    "CookieExpiration": 60
  },
  "PasswordPolicy": {
    "RequiredLength": 8,
    "RequireUppercase": false,
    "RequireLowercase": false,
    "RequireDigit": false,
    "RequireNonAlphanumeric": false
  },
  "QuizSettings": {
    "InputDocumentsPath": "App_Data"
  },
  "ExerciseSettings": {
    "EquationsFilePath": "App_Data/Equations.md",
    "CurrencyTolerance": 1.00,
    "RatioTolerance": 0.01
  },
  "StudyMaterials": {
    "MaxFileSizeBytes": 10485760,
    "StorageFolder": "StudyMaterials",
    "EnableEncryption": true
  }
}
