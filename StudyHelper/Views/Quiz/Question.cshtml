@model StudyHelper.ViewModels.QuizQuestionViewModel

@{
    ViewData["Title"] = "Quiz Question";
}

<div class="quiz-container">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="quiz-metadata mb-3">
        <span class="badge bg-primary">@Model.Module</span>
        <span class="badge bg-secondary">@Model.Topic</span>
        <span class="badge bg-info quiz-direction-badge" title="Question Direction">
            <i class="bi bi-arrow-left-right"></i> @Model.DirectionLabel
        </span>
    </div>

    <div class="card quiz-question-card shadow-sm">
        <div class="card-body">
            <h3 class="card-title quiz-question-text" id="question-text">@Model.QuestionText</h3>

            <form asp-controller="Quiz" asp-action="SubmitAnswer" method="post" class="quiz-form">
                @Html.AntiForgeryToken()

                <div class="quiz-answers" role="radiogroup" aria-labelledby="question-text">
                    @for (int i = 0; i < Model.AnswerOptions.Count; i++)
                    {
                        var optionLabel = (char)('A' + i);
                        <div class="form-check quiz-answer-option">
                            <input class="form-check-input" 
                                   type="radio" 
                                   name="selectedAnswerIndex" 
                                   id="answer@(i)" 
                                   value="@i" 
                                   required
                                   aria-describedby="answer@(i)-label">
                            <label class="form-check-label" id="answer@(i)-label" for="answer@(i)">
                                <strong>@optionLabel.</strong> @Model.AnswerOptions[i]
                            </label>
                        </div>
                    }
                </div>

                <div class="quiz-actions text-center mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">Submit Answer</button>
                </div>
            </form>
        </div>
    </div>

    <div class="quiz-navigation mt-3 text-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">← Back to Home</a>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/quiz.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/quiz-bidirectional.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/quiz.js" asp-append-version="true"></script>
}
