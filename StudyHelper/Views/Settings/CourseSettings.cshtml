@model StudyHelper.ViewModels.CourseSettingsViewModel
@{
    ViewData["Title"] = "Course Settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/course-settings.css" asp-append-version="true" />
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-10 mx-auto">

            <h1 class="mb-1">
                <i class="bi bi-mortarboard-fill"></i> Course Settings
            </h1>
            <p class="text-muted mb-4">Manage your courses and select which one you are currently studying.</p>

            @* ── Success / Error banners ── *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @* ── Active course banner ── *@
            @if (!string.IsNullOrEmpty(Model.ActiveCourseName))
            {
                <div class="alert alert-info mb-4" role="alert">
                    <i class="bi bi-bookmark-check-fill me-2"></i>
                    Active course: <strong>@Model.ActiveCourseName</strong>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-4" role="alert">
                    <i class="bi bi-bookmark-x-fill me-2"></i>
                    No active course selected. Use the <strong>Set Active</strong> button below to choose one.
                </div>
            }

            @* ── Course list ── *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>Your Courses
                    </h5>
                    <span class="badge bg-light text-primary">@Model.Courses.Count / 10</span>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Courses.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-folder-x fs-1 d-block mb-2"></i>
                            No courses yet. Add your first course below.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Course Name</th>
                                        <th>Instructor</th>
                                        <th>Created</th>
                                        <th>Updated</th>
                                        <th class="text-center">Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var course in Model.Courses)
                                    {
                                        <tr class="@(course.IsActive ? "table-success" : string.Empty)">
                                            <td>
                                                <strong>@course.CourseName</strong>
                                            </td>
                                            <td>@course.Instructor</td>
                                            <td class="text-nowrap">@course.CreatedDate.ToString("MMM dd, yyyy")</td>
                                            <td class="text-nowrap">@course.UpdatedDate.ToString("MMM dd, yyyy")</td>
                                            <td class="text-center">
                                                @if (course.IsActive)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-lg me-1"></i>Active
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td class="text-end text-nowrap">
                                                @* Set Active — hidden for the already-active row *@
                                                @if (!course.IsActive)
                                                {
                                                    <form asp-action="SetActiveCourse" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="courseName" value="@course.CourseName" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success me-1"
                                                                title="Set as active course">
                                                            <i class="bi bi-bookmark-check"></i> Set Active
                                                        </button>
                                                    </form>
                                                }

                                                @* Remove — opens confirmation modal *@
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#confirmRemoveModal"
                                                        data-course-name="@course.CourseName"
                                                        title="Remove this course">
                                                    <i class="bi bi-trash"></i> Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* ── Add Course form ── *@
            @if (Model.AtMaxCapacity)
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    You have reached the maximum of <strong>10 courses</strong>. Remove a course to add a new one.
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-plus-circle me-2"></i>Add a New Course
                        </h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="AddCourse" method="post" novalidate>
                            @Html.AntiForgeryToken()
                            @* Prefix matches the property name on CourseSettingsViewModel *@
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label asp-for="AddCourse.CourseName" class="form-label fw-semibold"></label>
                                    <input asp-for="AddCourse.CourseName"
                                           class="form-control"
                                           placeholder="e.g. Biology101"
                                           autocomplete="off" />
                                    <span asp-validation-for="AddCourse.CourseName" class="text-danger small"></span>
                                    <div class="form-text">Letters, numbers, hyphens and underscores only. No spaces.</div>
                                </div>
                                <div class="col-md-5">
                                    <label asp-for="AddCourse.Instructor" class="form-label fw-semibold"></label>
                                    <input asp-for="AddCourse.Instructor"
                                           class="form-control"
                                           placeholder="e.g. Dr. Smith"
                                           autocomplete="off" />
                                    <span asp-validation-for="AddCourse.Instructor" class="text-danger small"></span>
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary w-100">
                                        <i class="bi bi-plus-lg me-1"></i>Add
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@* ── Confirm Remove modal ── *@
<div class="modal fade" id="confirmRemoveModal" tabindex="-1"
     aria-labelledby="confirmRemoveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="confirmRemoveModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Remove Course
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>
                    Are you sure you want to remove course
                    <strong id="modalCourseName"></strong>?
                </p>
                <p class="text-danger mb-0">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    This will permanently delete the course directory and all its study materials.
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="RemoveCourse" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="modalCourseNameInput" name="courseName" value="" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Remove Course
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/course-settings.js" asp-append-version="true"></script>
}
