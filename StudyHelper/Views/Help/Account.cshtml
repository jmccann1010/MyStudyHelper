@{
    ViewData["Title"] = "Account Help";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Help" asp-action="Index">Help</a></li>
            <li class="breadcrumb-item active" aria-current="page">Account</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <div class="me-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-person-circle text-primary" viewBox="0 0 16 16">
                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
            </svg>
        </div>
        <div>
            <h1 class="mb-0">Account Help</h1>
            <p class="text-muted mb-0">Learn how to manage your StudyHelper account</p>
        </div>
    </div>

    <section id="overview" class="mb-5">
        <h2>Overview</h2>
        <p>
            Your StudyHelper account stores your custom study materials and preferences. Creating an account is free 
            and allows you to upload personalized content and access all study features.
        </p>
    </section>

    <section id="creating-account" class="mb-5">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">Creating an Account</h3>
            </div>
            <div class="card-body">
                <ol>
                    <li><strong>Click "Login":</strong> In the top-right corner of any page</li>
                    <li><strong>Select "Register":</strong> Click the registration link</li>
                    <li><strong>Enter Details:</strong> Provide a username, email, and secure password</li>
                    <li><strong>Submit:</strong> Click "Register" to create your account</li>
                    <li><strong>Login:</strong> Use your credentials to access study features</li>
                </ol>
            </div>
        </div>
    </section>

    <section id="logging-in" class="mb-5">
        <h2>Logging In & Out</h2>
        <ul>
            <li><strong>Login:</strong> Click "Login" in the top-right, enter your username and password, and click "Log In"</li>
            <li><strong>Logout:</strong> Click your username dropdown in the top-right and select "Logout"</li>
            <li><strong>Stay Logged In:</strong> Your session persists until you logout or close the browser</li>
        </ul>
        <div class="alert alert-info">
            <strong>Note:</strong> Some features (Quiz, Exercise, Flashcards, Study Materials) require you to be logged in.
        </div>
    </section>

    <section id="security" class="mb-5">
        <h2>Security & Privacy</h2>
        <div class="alert alert-success">
            <strong>Password Security:</strong> Use a strong, unique password. StudyHelper stores passwords securely using encryption.
        </div>
        <div class="alert alert-success">
            <strong>Data Privacy:</strong> Your study materials and progress are private and not shared with other users.
        </div>
        <div class="alert alert-warning">
            <strong>Important:</strong> If you forget your password, contact support to reset it. There is no self-service password reset at this time.
        </div>
    </section>

    <section id="troubleshooting" class="mb-5">
        <h2>Common Issues</h2>
        <div class="accordion" id="accountAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#issue1">
                        Problem: Can't log in
                    </button>
                </h2>
                <div id="issue1" class="accordion-collapse collapse" data-bs-parent="#accountAccordion">
                    <div class="accordion-body">
                        <p><strong>Solution:</strong></p>
                        <ul>
                            <li>Ensure your username and password are correct (case-sensitive)</li>
                            <li>Clear browser cache and cookies, then try again</li>
                            <li>Try a different browser</li>
                            <li>If still having issues, contact support</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#issue2">
                        Problem: Forgot password
                    </button>
                </h2>
                <div id="issue2" class="accordion-collapse collapse" data-bs-parent="#accountAccordion">
                    <div class="accordion-body">
                        <p><strong>Solution:</strong> Contact support to reset your password. Provide your username or email address for verification.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="related" class="mb-5">
        <div class="card bg-light">
            <div class="card-header"><h3 class="mb-0">Related Topics</h3></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <h5>Study Materials</h5>
                        <p>Learn how to upload custom content after creating an account.</p>
                        <a asp-controller="Help" asp-action="StudyMaterials" class="btn btn-sm btn-outline-primary">Learn More →</a>
                    </div>
                    <div class="col-md-6 mb-3">
                        <h5>Settings</h5>
                        <p>Customize your StudyHelper experience with themes and preferences.</p>
                        <a asp-controller="Help" asp-action="Settings" class="btn btn-sm btn-outline-primary">Learn More →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="text-center mb-4">
        <a asp-controller="Help" asp-action="Index" class="btn btn-outline-secondary">← Back to Help Overview</a>
    </div>
</div>
