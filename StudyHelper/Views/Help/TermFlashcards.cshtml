@{
    ViewData["Title"] = "Term Flashcards Help";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Help" asp-action="Index">Help</a></li>
            <li class="breadcrumb-item active" aria-current="page">Term Flashcards</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center mb-4">
        <div class="me-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-card-text text-info" viewBox="0 0 16 16">
                <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2h-13z"/>
                <path d="M3 5.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 8a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 8zm0 2.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/>
            </svg>
        </div>
        <div>
            <h1 class="mb-0">Term Flashcards Help</h1>
            <p class="text-muted mb-0">Learn how to use flashcards for memorizing terms and definitions</p>
        </div>
    </div>

    <section id="overview" class="mb-5">
        <h2>Overview</h2>
        <p>
            Term Flashcards help you memorize accounting terms and definitions using the proven flashcard study method. 
            Each card shows a term on the front and its definition on the back. Flip cards to test your memory and 
            reinforce your understanding.
        </p>
    </section>

    <section id="getting-started" class="mb-5">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h3 class="mb-0">Getting Started</h3>
            </div>
            <div class="card-body">
                <ol>
                    <li><strong>Navigate:</strong> Click "Term Flashcards" from the home page.</li>
                    <li><strong>View Term:</strong> The front of the card shows an accounting term.</li>
                    <li><strong>Try to Recall:</strong> Think of the definition before flipping.</li>
                    <li><strong>Flip Card:</strong> Click "Flip Card" to reveal the definition.</li>
                    <li><strong>Continue:</strong> Click "Next Card" to move to the next term.</li>
                </ol>
            </div>
        </div>
    </section>

    <section id="tips" class="mb-5">
        <h2>Tips & Best Practices</h2>
        <div class="alert alert-success">
            <strong>Try to Recall First:</strong> Before flipping, attempt to recall the definition. This strengthens memory retention.
        </div>
        <div class="alert alert-success">
            <strong>Study in Small Sessions:</strong> Review 10-15 cards at a time for better focus and retention.
        </div>
        <div class="alert alert-success">
            <strong>Repeat Regularly:</strong> Spaced repetition (reviewing the same cards multiple times over days) improves long-term memory.
        </div>
    </section>

    <section id="related" class="mb-5">
        <div class="card bg-light">
            <div class="card-header"><h3 class="mb-0">Related Topics</h3></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <h5>Equation Flashcards</h5>
                        <p>Review accounting equations and formulas in flashcard format.</p>
                        <a asp-controller="Help" asp-action="EquationFlashcards" class="btn btn-sm btn-outline-primary">Learn More →</a>
                    </div>
                    <div class="col-md-6 mb-3">
                        <h5>Quiz</h5>
                        <p>Test your knowledge with multiple-choice questions about terms.</p>
                        <a asp-controller="Help" asp-action="Quiz" class="btn btn-sm btn-outline-primary">Learn More →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="text-center mb-4">
        <a asp-controller="Help" asp-action="Index" class="btn btn-outline-secondary">← Back to Help Overview</a>
    </div>
</div>
